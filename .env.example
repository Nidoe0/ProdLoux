APP_NAME="Tsena Mora"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_TIMEZONE=Indian/Antananarivo

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite (dev)
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tsenamora
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file
BROADCAST_CONNECTION=log

# Mail
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@tsenamora.mg"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe
STRIPE_KEY=pk_test_XXXX
STRIPE_SECRET=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# Commission plateforme (%)
PLATFORM_COMMISSION=10

# Stock bas seuil
LOW_STOCK_THRESHOLD=5
